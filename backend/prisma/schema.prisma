generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String
  role      String
  processes Process[]
}

model Client {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  type       String    @default("PF")
  cpfCnpj    String?
  phone      String?
  email      String?
  address    String?
  status     String    @default("ativo")
  legalArea  String?
  responsible String?
  notes      String?
  createdAt  DateTime  @default(now())
  processes  Process[]
}

model Process {
  id           Int           @id @default(autoincrement())
  title        String
  client       String
  clientId     Int?
  clientRecord Client?       @relation(fields: [clientId], references: [id])
  phase        String
  status       String
  ownerId      Int
  owner        User          @relation(fields: [ownerId], references: [id])
  andamentos   Andamento[]
  prazos       Prazo[]
  documentos   Documento[]
  atendimentos Atendimento[]
}

model Andamento {
  id          Int      @id @default(autoincrement())
  processId   Int
  process     Process  @relation(fields: [processId], references: [id])
  title       String
  description String
  date        DateTime @default(now())
  actorEmail  String
}

model Prazo {
  id        Int      @id @default(autoincrement())
  processId Int
  process   Process  @relation(fields: [processId], references: [id])
  title     String
  dueDate   DateTime
  status    String   @default("pendente")
  priority  String   @default("media")
}

model Documento {
  id          Int     @id @default(autoincrement())
  processId   Int
  process     Process @relation(fields: [processId], references: [id])
  title       String
  description String
  status      String  @default("pendente")
}

model Atendimento {
  id          Int      @id @default(autoincrement())
  processId   Int
  process     Process  @relation(fields: [processId], references: [id])
  title       String
  description String
  date        DateTime @default(now())
  actorEmail  String
}
