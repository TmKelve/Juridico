generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                 @id @default(autoincrement())
  email                  String              @unique
  password               String
  role                   String
  companyMemberships     CompanyMembership[]
  processes              Process[]
  ownedTasks             Task[]              @relation("TaskOwnerUser")
  responsibleAttendances Atendimento[]       @relation("AttendanceResponsibleUser")
  teamMemberships        TeamMember[]
  primaryPortfolios      Portfolio[]         @relation("PortfolioPrimaryOwner")
  backupPortfolios       Portfolio[]         @relation("PortfolioBackupOwner")
  portfolioMemberships   PortfolioMember[]
  timeEntries            TimeEntry[]         @relation("TimeEntryUser")
  createdTimeEntries     TimeEntry[]         @relation("TimeEntryCreator")
  approvedTimeEntries    TimeEntry[]         @relation("TimeEntryApprover")
  timeEntryApprovals     TimeEntryApproval[] @relation("TimeEntryApprovalApprover")
  closedTimesheetClosures TimesheetClosure[] @relation("TimesheetClosedByUser")
  avatarUrl              String?
  phone                  String?
  notifications          Notification[]
}

enum CompanyStatus {
  active
  grace_period
  read_only
  suspended
  cancelled
}

enum SubscriptionStatus {
  draft
  checkout_pending
  active
  past_due
  grace_period
  read_only
  suspended
  cancelled
}

model Company {
  id          Int                 @id @default(autoincrement())
  name        String
  slug        String              @unique
  status      CompanyStatus       @default(active)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  memberships CompanyMembership[]
  subscriptions Subscription[]
  billingInvoices BillingInvoice[]
  paymentAttempts PaymentAttempt[]
  billingEvents BillingEvent[]

  @@unique([name])
}

model Plan {
  id            Int            @id @default(autoincrement())
  code          String         @unique
  name          String
  description   String?
  priceCents    Int
  currency      String         @default("BRL")
  billingCycle  String         @default("monthly")
  active        Boolean        @default(true)
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([active, code])
}

model Subscription {
  id                 Int                     @id @default(autoincrement())
  companyId          Int
  company            Company                 @relation(fields: [companyId], references: [id])
  planId             Int
  plan               Plan                    @relation(fields: [planId], references: [id])
  status             SubscriptionStatus      @default(draft)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  checkoutReference  String?
  externalReference  String?
  cancelledAt        DateTime?
  metadata           Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  transitions        SubscriptionTransition[]

  @@index([companyId, status])
  @@index([planId, status])
}

model SubscriptionTransition {
  id               Int                @id @default(autoincrement())
  subscriptionId   Int
  subscription     Subscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  fromStatus       SubscriptionStatus
  toStatus         SubscriptionStatus
  reason           String?
  actor            String?
  idempotencyKey   String?
  metadata         Json?
  createdAt        DateTime           @default(now())

  @@unique([subscriptionId, idempotencyKey], name: "subscription_transition_idempotency")
  @@index([subscriptionId, createdAt])
}

model CompanyMembership {
  id         Int      @id @default(autoincrement())
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  role       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([userId, active])
}

model Team {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  slug        String            @unique
  description String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships TeamMember[]
  portfolios  Portfolio[]
  tasks       Task[]
  attendances Atendimento[]
  timeEntries TimeEntry[]
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  role      String
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
}

model Portfolio {
  id                 Int               @id @default(autoincrement())
  name               String
  code               String            @unique
  teamId             Int
  team               Team              @relation(fields: [teamId], references: [id])
  primaryOwnerUserId Int
  primaryOwner       User              @relation("PortfolioPrimaryOwner", fields: [primaryOwnerUserId], references: [id])
  backupOwnerUserId  Int?
  backupOwner        User?             @relation("PortfolioBackupOwner", fields: [backupOwnerUserId], references: [id])
  active             Boolean           @default(true)
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  memberships        PortfolioMember[]
  tasks              Task[]
  attendances        Atendimento[]
  timeEntries        TimeEntry[]

  @@unique([teamId, name])
}

model PortfolioMember {
  id          Int       @id @default(autoincrement())
  portfolioId Int
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  role        String    @default("member")
  isBackup    Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([portfolioId, userId])
}

model Client {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  type       String    @default("PF")
  cpfCnpj    String?
  phone      String?
  email      String?
  address    String?
  status     String    @default("ativo")
  legalArea  String?
  responsible String?
  notes      String?
  createdAt  DateTime  @default(now())
  processes  Process[]
  atendimentos Atendimento[]
  tasks      Task[]
  agendaEvents AgendaEvent[]
  publications Publication[]
  publicationEvents PublicationEvent[]
  triageItems TriageItem[]
  crmLeads CrmLead[]
  crmOpportunities CrmOpportunity[]
  financeEntries FinanceEntry[]
  financeInstallmentPlans FinanceInstallmentPlan[]
  timeEntries TimeEntry[]
}

model Process {
  id           Int           @id @default(autoincrement())
  title        String
  processNumber String?      @unique
  client       String
  clientId     Int?
  clientRecord Client?       @relation(fields: [clientId], references: [id])
  phase        String
  status       String
  ownerId      Int
  owner        User          @relation(fields: [ownerId], references: [id])
  andamentos   Andamento[]
  prazos       Prazo[]
  documentos   Documento[]
  atendimentos Atendimento[]
  tasks        Task[]
  agendaEvents AgendaEvent[]
  publications Publication[]
  publicationEvents PublicationEvent[]
  triageItems TriageItem[]
  financeEntries FinanceEntry[]
  financeInstallmentPlans FinanceInstallmentPlan[]
  timeEntries TimeEntry[]
}

model Publication {
  id                Int      @id @default(autoincrement())
  processId         Int
  process           Process  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?  @relation(fields: [clientId], references: [id])
  publicationType   String
  status            String   @default("nova")
  impact            String   @default("medio")
  tribunal          String
  origin            String
  publishedAt       DateTime
  summary           String
  relevantText      String
  requiresAction    Boolean  @default(false)
  convertedToDeadline Boolean @default(false)
  derivedDeadlineLabel String?
  derivedDeadlineId Int?
  correlationId     String?
  sourceType        String?
  sourceReference   String?
  originStage       String?
  consolidationStatus String?
  notes             String?
  read              Boolean  @default(false)
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  publicationEvents PublicationEvent[]
}

model PublicationCapture {
  id                Int      @id @default(autoincrement())
  sourceType        String
  sourceReference   String
  correlationId     String?
  originStage       String?
  pipelineStatus    String?
  consolidationStatus String?
  capturedAt        DateTime @default(now())
  occurredAt        DateTime
  rawText           String
  normalizedText    String
  tribunal          String?
  processNumber     String?
  oabNumber         String?
  lawyerName        String?
  cpf               String?
  personName        String?
  metadataJson      Json
  fingerprint       String   @unique
  status            String   @default("novo")
  sourceJobId       Int?
  sourceJob         PublicationSourceJob? @relation(fields: [sourceJobId], references: [id])
  publicationEvents PublicationEvent[]
  triageItems       TriageItem[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PublicationEvent {
  id               Int      @id @default(autoincrement())
  captureId        Int
  capture          PublicationCapture @relation(fields: [captureId], references: [id])
  processId        Int?
  process          Process? @relation(fields: [processId], references: [id])
  clientId         Int?
  clientRecord     Client?  @relation(fields: [clientId], references: [id])
  publicationId    Int?
  publication      Publication? @relation(fields: [publicationId], references: [id])
  correlationId    String?
  sourceType       String?
  sourceReference  String?
  originStage      String?
  pipelineStatus   String?
  eventType        String
  eventAt          DateTime
  title            String
  summary          String
  fullText         String
  riskLevel        String   @default("normal")
  requiresAction   Boolean  @default(false)
  timelinePosition Int      @default(0)
  triageItems      TriageItem[]
  createdAt        DateTime @default(now())
}

model PublicationSourceJob {
  id                Int      @id @default(autoincrement())
  sourceType        String
  scheduledFor      DateTime
  startedAt         DateTime?
  finishedAt        DateTime?
  status            String   @default("pending")
  itemsCaptured     Int      @default(0)
  itemsCreated      Int      @default(0)
  itemsUpdated      Int      @default(0)
  itemsFlaggedCritical Int   @default(0)
  itemsSentToCrm    Int      @default(0)
  errorLog          String?
  captures          PublicationCapture[]
  createdAt         DateTime @default(now())
}

model CrmLead {
  id             Int      @id @default(autoincrement())
  clientId       Int?
  clientRecord   Client?  @relation(fields: [clientId], references: [id])
  cpf            String?
  personName     String
  source         String
  correlationId  String?
  sourceType     String?
  sourceReference String?
  originStage    String?
  captureId      Int?
  eventId        Int?
  publicationId  Int?
  consolidationStatus String?
  status         String   @default("novo")
  responsible    String?
  summary        String
  lastContactAt  DateTime?
  nextContactAt  DateTime?
  contactEvents  CrmContactEvent[]
  triageItems    TriageItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CrmOpportunity {
  id                  Int                              @id @default(autoincrement())
  clientId            Int?
  clientRecord        Client?                          @relation(fields: [clientId], references: [id])
  convertedProcessId  Int?
  cpf                 String?
  personName          String
  source              String
  correlationId       String?
  sourceType          String?
  sourceReference     String?
  originStage         String?
  captureId           Int?
  eventId             Int?
  publicationId       Int?
  consolidationStatus String?
  status              String                           @default("acao_recomendada")
  responsible         String?
  summary             String
  lastContactAt       DateTime?
  nextContactAt       DateTime?
  contactEvents       CrmContactEvent[]
  documentAttachments CrmOpportunityDocumentAttachment[]
  triageItems         TriageItem[]
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt
}

model CrmContactEvent {
  id               Int             @id @default(autoincrement())
  crmLeadId        Int?
  crmLead          CrmLead?        @relation(fields: [crmLeadId], references: [id])
  crmOpportunityId Int?
  crmOpportunity   CrmOpportunity? @relation(fields: [crmOpportunityId], references: [id])
  kind             String          @default("contato")
  summary          String
  createdBy        String?
  createdAt        DateTime        @default(now())
}

model CrmOpportunityDocumentAttachment {
  id                Int            @id @default(autoincrement())
  crmOpportunityId  Int
  crmOpportunity    CrmOpportunity @relation(fields: [crmOpportunityId], references: [id])
  documentId        Int?
  document          Documento?     @relation(fields: [documentId], references: [id])
  titleSnapshot     String
  category          String         @default("Checklist")
  status            String         @default("ativo")
  mimeType          String         @default("application/octet-stream")
  previewUrl        String?
  requiredChecklist Boolean        @default(false)
  pendingForAdvance Boolean        @default(false)
  uploadedAt        DateTime       @default(now())
  responsible       String?
  createdBy         String?
  externalDocumentId String?
  metadata          Json
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model CrmAuditEvent {
  id             String   @id
  scope          String
  entityType     String
  entityId       Int?
  action         String
  status         String
  summary        String
  details        Json
  actor          Json
  occurredAt     DateTime
  correlationId  String?
  idempotencyKey String?
  createdAt      DateTime @default(now())
}

model CrmIdempotencyRequest {
  id           Int      @id @default(autoincrement())
  key          String
  scope        String
  entityType   String
  entityId     Int?
  action       String
  payloadHash  String
  responseCode Int
  responseBody Json
  auditEventId String?
  createdAt    DateTime @default(now())

  @@unique([scope, key], name: "scope_key")
}

model TriageItem {
  id               Int      @id @default(autoincrement())
  captureId        Int
  capture          PublicationCapture @relation(fields: [captureId], references: [id])
  eventId          Int?
  event            PublicationEvent? @relation(fields: [eventId], references: [id])
  processId        Int?
  process          Process? @relation(fields: [processId], references: [id])
  clientId         Int?
  clientRecord     Client?  @relation(fields: [clientId], references: [id])
  crmLeadId        Int?
  crmLead          CrmLead? @relation(fields: [crmLeadId], references: [id])
  crmOpportunityId Int?
  crmOpportunity   CrmOpportunity? @relation(fields: [crmOpportunityId], references: [id])
  correlationId    String?
  sourceType       String?
  sourceReference  String?
  originStage      String?
  pipelineStatus   String?
  publicationId    Int?
  queueType        String
  status           String   @default("pendente")
  suggestedAction  String
  suggestedReason  String
  aiConfidenceBand String?
  aiScoreRaw       Float?
  postponeUntil    DateTime?
  assignedQueue    String   @default("fila_central")
  handledBy        String?
  handledAt        DateTime?
  discardReason    String?
  discardNote      String?
  sourceLabel      String?
  decisions        TriageDecision[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TriageDecision {
  id                     Int      @id @default(autoincrement())
  triageItemId           Int
  triageItem             TriageItem @relation(fields: [triageItemId], references: [id])
  decisionType           String
  decisionReason         String?
  decisionNote           String?
  decidedBy              String
  decidedAt              DateTime @default(now())
  generatedTaskId        Int?
  generatedDeadlineId    Int?
  generatedLeadId        Int?
  generatedOpportunityId Int?
}

model Andamento {
  id          Int      @id @default(autoincrement())
  processId   Int
  process     Process  @relation(fields: [processId], references: [id])
  title       String
  description String
  date        DateTime @default(now())
  actorEmail  String
}

model Prazo {
  id                      Int         @id @default(autoincrement())
  processId               Int
  process                 Process     @relation(fields: [processId], references: [id])
  title                   String
  dueDate                 DateTime
  status                  String      @default("aberto")
  priority                String      @default("media")
  origin                  String      @default("interno")
  responsible             String?
  legalArea               String?
  notes                   String?
  publicationId           Int?
  correlationId           String?
  sourceType              String?
  sourceReference         String?
  originStage             String?
  agendaEventId           Int?        @unique
  agendaEvent             AgendaEvent? @relation(fields: [agendaEventId], references: [id])
  agendaSyncStatus        String?     @default("missing")
  completedAt             DateTime?
  completedBy             String?
  completionJustification String?
  createdBy               String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model Documento {
  id                Int      @id @default(autoincrement())
  processId         Int
  process           Process  @relation(fields: [processId], references: [id])
  title             String
  description       String
  status            String   @default("pendente")
  category          String   @default("Checklist")
  version           Int      @default(1)
  isLatestVersion   Boolean  @default(true)
  origin            String   @default("interno")
  uploadedAt        DateTime @default(now())
  responsible       String?
  requiredChecklist Boolean  @default(false)
  pendingForAdvance Boolean  @default(false)
  mimeType          String   @default("application/octet-stream")
  previewUrl        String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  crmOpportunityAttachments CrmOpportunityDocumentAttachment[]
}

model Atendimento {
  id                Int       @id @default(autoincrement())
  processId         Int?
  process           Process?  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?   @relation(fields: [clientId], references: [id])
  responsibleUserId Int?
  responsibleUser   User?     @relation("AttendanceResponsibleUser", fields: [responsibleUserId], references: [id])
  teamId            Int?
  team              Team?     @relation(fields: [teamId], references: [id])
  portfolioId       Int?
  portfolio         Portfolio? @relation(fields: [portfolioId], references: [id])
  subject           String    @map("title")
  summary           String    @map("description")
  notes             String?
  occurredAt        DateTime  @default(now()) @map("date")
  channel           String    @default("interno")
  type              String    @default("rotina")
  status            String    @default("aberto")
  priority          String    @default("media")
  responsible       String?
  nextStep          String?
  scheduledReturnAt DateTime?
  critical          Boolean   @default(false)
  slaPolicyCode     String    @default("default")
  slaTargetAt       DateTime?
  slaBreachedAt     DateTime?
  convertedTaskId   Int?
  convertedDeadlineId Int?
  actorEmail        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  agendaEvents      AgendaEvent[]
  history           AttendanceHistory[]
  timeEntries       TimeEntry[]
}

model Task {
  id                Int       @id @default(autoincrement())
  title             String
  description       String
  processId         Int?
  process           Process?  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?   @relation(fields: [clientId], references: [id])
  ownerUserId       Int?
  ownerUser         User?     @relation("TaskOwnerUser", fields: [ownerUserId], references: [id])
  teamId            Int?
  team              Team?     @relation(fields: [teamId], references: [id])
  portfolioId       Int?
  portfolio         Portfolio? @relation(fields: [portfolioId], references: [id])
  clientName        String?
  origin            String    @default("interno")
  correlationId     String?
  sourceType        String?
  sourceReference   String?
  originStage       String?
  dueDate           DateTime
  status            String    @default("pendente")
  priority          String    @default("media")
  workflowStage     String    @default("captura")
  owner             String
  createdBy         String
  notes             String?
  linkedToDeadline  Boolean   @default(false)
  linkedToPublication Boolean @default(false)
  linkedToDocument  Boolean   @default(false)
  immediateAction   Boolean   @default(false)
  slaTargetAt       DateTime?
  followupState     String    @default("idle")
  lastFollowupAt    DateTime?
  breachedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  agendaEvents      AgendaEvent[]
  links             TaskLink[]
  followupSchedules TaskFollowupSchedule[]
  history           TaskHistory[]
  timeEntries       TimeEntry[]
}

model TaskLink {
  id         Int      @id @default(autoincrement())
  taskId      Int
  task        Task     @relation(fields: [taskId], references: [id])
  entityType  String
  entityId    Int
  createdAt   DateTime @default(now())

  @@unique([taskId, entityType, entityId])
}

model TaskFollowupSchedule {
  id           Int      @id @default(autoincrement())
  taskId        Int
  task          Task     @relation(fields: [taskId], references: [id])
  followupAt    DateTime
  reason        String
  channel       String   @default("in_app")
  state         String   @default("scheduled")
  dedupeKey     String   @unique
  dispatchedAt  DateTime?
  acknowledgedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([state, followupAt])
}

model TaskHistory {
  id              Int      @id @default(autoincrement())
  taskId           Int
  task             Task     @relation(fields: [taskId], references: [id])
  eventType        String
  fromStatus       String?
  toStatus         String?
  fromOwnerUserId  Int?
  toOwnerUserId    Int?
  fromTeamId       Int?
  toTeamId         Int?
  actor            String
  details          Json?
  correlationId    String?
  idempotencyKey   String?
  occurredAt       DateTime @default(now())

  @@index([taskId, occurredAt])
}

model AttendanceHistory {
  id                   Int      @id @default(autoincrement())
  attendanceId         Int
  attendance           Atendimento @relation(fields: [attendanceId], references: [id])
  eventType            String
  fromStatus           String?
  toStatus             String?
  fromResponsibleUserId Int?
  toResponsibleUserId  Int?
  fromTeamId           Int?
  toTeamId             Int?
  actor                String
  details              Json?
  correlationId        String?
  idempotencyKey       String?
  occurredAt           DateTime @default(now())

  @@index([attendanceId, occurredAt])
}

model WorkAuditEvent {
  id             String   @id
  scope          String
  entityType     String
  entityId       String?
  action         String
  status         String
  summary        String
  details        Json
  actor          Json
  occurredAt     DateTime
  correlationId  String?
  idempotencyKey String?
  createdAt      DateTime @default(now())

  @@index([scope, occurredAt])
  @@index([entityType, entityId])
}

model WorkIdempotencyRequest {
  id           Int      @id @default(autoincrement())
  key          String
  scope        String
  entityType   String
  entityId     String?
  action       String
  payloadHash  String
  responseCode Int
  responseBody Json
  auditEventId String?
  createdAt    DateTime @default(now())

  @@unique([scope, key], name: "work_scope_key")
}

model AiExecution {
  id                String   @id
  commandKey        String
  targetType        String
  targetId          String
  promptVersion     String
  modelVersion      String
  provider          String
  status            String
  inputHash         String?
  outputHash        String?
  maskedInput       Json?
  outputPayload     Json?
  fallbackUsed      Boolean  @default(false)
  guardrailStatus   String   @default("passed")
  tokenUsageInput   Int      @default(0)
  tokenUsageOutput  Int      @default(0)
  estimatedCostUsd  Decimal? @db.Decimal(12, 6)
  latencyMs         Int?
  actor             String
  correlationId     String?
  idempotencyKey    String?
  startedAt         DateTime
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  targets           AiExecutionTarget[]

  @@index([commandKey, createdAt])
  @@index([targetType, targetId])
  @@index([status, createdAt])
}

model AiExecutionTarget {
  id            Int         @id @default(autoincrement())
  executionId   String
  execution     AiExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  targetType    String
  targetId      String
  processId     Int?
  clientId      Int?
  portfolioId   Int?
  teamId        Int?
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([targetType, targetId])
  @@index([processId])
  @@index([clientId])
}

model AiBudgetLedger {
  id                Int      @id @default(autoincrement())
  scopeType         String
  scopeId           String
  commandKey        String
  periodStart       DateTime
  periodEnd         DateTime
  requestCount      Int      @default(0)
  tokenUsageInput   Int      @default(0)
  tokenUsageOutput  Int      @default(0)
  estimatedCostUsd  Decimal  @default(0) @db.Decimal(12, 6)
  hardLimitUsd      Decimal? @db.Decimal(12, 6)
  softLimitUsd      Decimal? @db.Decimal(12, 6)
  lastExecutionId   String?
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([scopeType, scopeId, commandKey, periodStart, periodEnd], name: "ai_budget_scope_period")
}

model BiMetricDefinition {
  id                Int      @id @default(autoincrement())
  metricKey         String
  label             String
  description       String
  formula           String
  sourceOfTruth     String
  ownerDomain       String
  dashboardKeys     Json
  timezonePolicy    String
  aggregationPolicy String
  version           String
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([metricKey, version], name: "bi_metric_definition_key_version")
  @@index([metricKey, active])
}

model BiMetricSnapshot {
  id                String   @id
  snapshotKey       String
  metricKey         String
  dashboardKey      String?
  scopeType         String
  scopeId           String
  timezone          String
  referenceDate     DateTime
  windowFrom        DateTime
  windowTo          DateTime
  asOf              DateTime?
  valueNumeric      Decimal? @db.Decimal(18, 4)
  valueText         String?
  deltaNumeric      Decimal? @db.Decimal(18, 4)
  series            Json?
  dimensions        Json?
  definitionVersion String
  sourceHash        String?
  generatedBy       String
  createdAt         DateTime @default(now())

  @@unique([metricKey, scopeType, scopeId, referenceDate, windowFrom, windowTo], name: "bi_metric_snapshot_unique")
  @@index([dashboardKey, referenceDate])
  @@index([scopeType, scopeId, referenceDate])
}

model BiExportJob {
  id                String   @id
  dashboardKey      String
  format            String
  status            String   @default("pending")
  scopeType         String
  scopeId           String
  timezone          String
  asOf              DateTime?
  snapshotId        String?
  filters           Json
  artifactPath      String?
  requestedBy       String
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([dashboardKey, createdAt])
  @@index([status, createdAt])
}

model TimeEntry {
  id                String        @id
  userId            Int
  user              User          @relation("TimeEntryUser", fields: [userId], references: [id])
  teamId            Int?
  team              Team?         @relation(fields: [teamId], references: [id])
  portfolioId       Int?
  portfolio         Portfolio?    @relation(fields: [portfolioId], references: [id])
  clientId          Int?
  clientRecord      Client?       @relation(fields: [clientId], references: [id])
  processId         Int?
  process           Process?      @relation(fields: [processId], references: [id])
  taskId            Int?
  task              Task?         @relation(fields: [taskId], references: [id])
  attendanceId      Int?
  attendance        Atendimento?  @relation(fields: [attendanceId], references: [id])
  agendaEventId     Int?
  agendaEvent       AgendaEvent?  @relation(fields: [agendaEventId], references: [id])
  activityType      String
  source            String        @default("manual")
  status            String        @default("draft")
  billable          Boolean       @default(true)
  durationMinutes   Int
  billableMinutes   Int
  startedAt         DateTime
  endedAt           DateTime
  notes             String?
  origin            String        @default("manual")
  createdByUserId   Int?
  createdByUser     User?         @relation("TimeEntryCreator", fields: [createdByUserId], references: [id])
  approvedByUserId  Int?
  approvedByUser    User?         @relation("TimeEntryApprover", fields: [approvedByUserId], references: [id])
  approvedAt        DateTime?
  lockedAt          DateTime?
  correlationId     String?
  idempotencyKey    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  approvals         TimeEntryApproval[]
  conflicts         TimeEntryConflict[]
  financeLinks      TimeEntryFinanceLink[]

  @@index([userId, startedAt])
  @@index([teamId, startedAt])
  @@index([portfolioId, startedAt])
  @@index([processId, startedAt])
  @@index([taskId, startedAt])
  @@index([status, startedAt])
}

model TimeEntryApproval {
  id                String     @id
  entryId           String
  entry             TimeEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  decision          String
  reason            String?
  approverUserId    Int
  approverUser      User       @relation("TimeEntryApprovalApprover", fields: [approverUserId], references: [id])
  periodStart       DateTime?
  periodEnd         DateTime?
  createdAt         DateTime   @default(now())

  @@index([entryId, createdAt])
  @@index([approverUserId, createdAt])
}

model TimesheetClosure {
  id                String   @id
  scopeType         String
  scopeId           String
  periodStart       DateTime
  periodEnd         DateTime
  status            String   @default("closed")
  closedByUserId    Int
  closedByUser      User     @relation("TimesheetClosedByUser", fields: [closedByUserId], references: [id])
  reason            String?
  reopenedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([scopeType, scopeId, periodStart, periodEnd], name: "timesheet_closure_scope_period")
  @@index([status, periodStart, periodEnd])
}

model TimeEntryConflict {
  id                String    @id
  entryId           String
  entry             TimeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  conflictType      String
  severity          String
  fingerprint       String
  details           Json
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@unique([entryId, fingerprint], name: "time_entry_conflict_entry_fingerprint")
  @@index([conflictType, createdAt])
}

model TimeEntryFinanceLink {
  id                String       @id
  entryId           String
  entry             TimeEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  financeEntryId    Int
  financeEntry      FinanceEntry @relation(fields: [financeEntryId], references: [id], onDelete: Restrict)
  linkType          String
  allocatedCents    Int?
  createdAt         DateTime     @default(now())

  @@unique([entryId, financeEntryId], name: "time_entry_finance_link_unique")
  @@index([financeEntryId])
}

model ProductivitySnapshot {
  id                 Int      @id @default(autoincrement())
  referenceDate      DateTime
  scopeType          String
  scopeId            String
  tasksCompleted     Int      @default(0)
  tasksOverdue       Int      @default(0)
  attendancesHandled Int      @default(0)
  slaBreaches        Int      @default(0)
  avgResolutionHours Float?
  reassignments      Int      @default(0)
  metrics            Json
  createdAt          DateTime @default(now())

  @@unique([referenceDate, scopeType, scopeId], name: "productivity_snapshot_scope")
}

model AgendaEvent {
  id                Int          @id @default(autoincrement())
  title             String
  eventType         String
  status            String       @default("agendado")
  priority          String       @default("media")
  startAt           DateTime
  endAt             DateTime
  processId         Int?
  process           Process?     @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?      @relation(fields: [clientId], references: [id])
  attendanceId      Int?
  attendance        Atendimento? @relation(fields: [attendanceId], references: [id])
  taskId            Int?
  task              Task?        @relation(fields: [taskId], references: [id])
  responsible       String?
  locationOrChannel String?
  notes             String?
  origin            String       @default("manual")
  createdBy         String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deadline          Prazo?
  timeEntries       TimeEntry[]
}

model Template {
  id               Int      @id @default(autoincrement())
  name             String
  legalArea        String
  pieceType        String
  status           String   @default("ativo")
  official         Boolean  @default(false)
  favorite         Boolean  @default(false)
  autoFill         Boolean  @default(false)
  phase            String
  author           String
  version          String   @default("v1.0")
  updatedOn        DateTime @default(now())
  lastUsedAt       DateTime?
  needsReview      Boolean  @default(false)
  description      String
  tags             Json
  placeholders     Json
  preview          String
  versionsJson     Json
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FinanceCategory {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  label       String
  type        String
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  entries     FinanceEntry[]
  installmentPlans FinanceInstallmentPlan[]
}

model FinanceEntry {
  id                Int             @id @default(autoincrement())
  type              String
  status            String          @default("open")
  description       String
  amountCents       Int
  settledAmountCents Int            @default(0)
  currency          String          @default("BRL")
  dueDate           DateTime
  settlementDate    DateTime?
  paymentMethod     String?
  referenceNumber   String?
  clientId          Int?
  clientRecord      Client?         @relation(fields: [clientId], references: [id])
  processId         Int?
  process           Process?        @relation(fields: [processId], references: [id])
  installmentPlanId Int?
  installmentPlan   FinanceInstallmentPlan? @relation(fields: [installmentPlanId], references: [id])
  installmentNumber Int?
  categoryCode      String
  category          FinanceCategory @relation(fields: [categoryCode], references: [code])
  responsibleUserId Int?
  notes             String?
  externalRef       String?
  createdBy         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  charges           FinanceCharge[]
  reconciliationMatches FinanceReconciliationMatch[]
  collectionSchedules FinanceCollectionSchedule[]
  timeEntryLinks    TimeEntryFinanceLink[]

  @@index([type, status, dueDate])
  @@index([clientId, status])
  @@index([processId, status])
  @@index([installmentPlanId, installmentNumber])
}

model FinanceInstallmentPlan {
  id                    Int            @id @default(autoincrement())
  description           String
  clientId              Int?
  clientRecord          Client?        @relation(fields: [clientId], references: [id])
  processId             Int?
  process               Process?       @relation(fields: [processId], references: [id])
  categoryCode          String
  category              FinanceCategory @relation(fields: [categoryCode], references: [code])
  installmentCount      Int
  installmentAmountCents Int
  totalAmountCents      Int
  dueDay                Int
  firstDueDate          DateTime
  active                Boolean        @default(true)
  notes                 String?
  createdBy             String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  entries               FinanceEntry[]

  @@index([clientId, active])
  @@index([processId, active])
}

model FinanceCharge {
  id              Int      @id @default(autoincrement())
  entryId         Int
  entry           FinanceEntry @relation(fields: [entryId], references: [id])
  method          String
  status          String   @default("draft")
  provider        String   @default("mock")
  externalId      String   @unique
  paymentUrl      String?
  pixCode         String?
  boletoBarcode   String?
  expiresAt       DateTime?
  paidAt          DateTime?
  amountCents     Int
  recipientEmail  String?
  recipientPhone  String?
  providerPayload Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  events          FinanceChargeEvent[]

  @@index([entryId, status])
}

model FinanceChargeEvent {
  id            Int      @id @default(autoincrement())
  chargeId      Int
  charge        FinanceCharge @relation(fields: [chargeId], references: [id])
  providerEventId String?
  eventType     String
  status        String
  payload       Json
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  @@unique([chargeId, providerEventId], name: "charge_provider_event_unique")
}

model FinanceReconciliationRun {
  id            Int      @id @default(autoincrement())
  referenceDate DateTime
  status        String   @default("pending")
  source        String   @default("manual")
  importedLines Int      @default(0)
  matchedLines  Int      @default(0)
  unmatchedLines Int     @default(0)
  summaryJson   Json
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  matches       FinanceReconciliationMatch[]
}

model FinanceReconciliationMatch {
  id            Int      @id @default(autoincrement())
  runId         Int
  run           FinanceReconciliationRun @relation(fields: [runId], references: [id])
  entryId       Int?
  entry         FinanceEntry? @relation(fields: [entryId], references: [id])
  externalId    String
  status        String   @default("pending")
  occurredAt    DateTime
  amountCents   Int
  description   String
  matchedAt     DateTime?
  metadata      Json
  createdAt     DateTime @default(now())

  @@index([runId, status])
  @@index([entryId, status])
}

model FinanceCollectionSchedule {
  id              Int      @id @default(autoincrement())
  entryId         Int
  entry           FinanceEntry @relation(fields: [entryId], references: [id])
  channel         String
  cadenceDays     Int
  maxAttempts     Int
  startsAt        DateTime
  nextRunAt       DateTime
  active          Boolean  @default(true)
  lastAttemptAt   DateTime?
  status          String   @default("scheduled")
  templateCode    String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  attempts        FinanceCollectionAttempt[]
}

model FinanceCollectionAttempt {
  id            Int      @id @default(autoincrement())
  scheduleId    Int
  schedule      FinanceCollectionSchedule @relation(fields: [scheduleId], references: [id])
  attemptNumber Int
  status        String   @default("scheduled")
  channel       String
  destination   String?
  message       String
  providerPayload Json
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@unique([scheduleId, attemptNumber], name: "collection_schedule_attempt_unique")
}

model FinanceAuditEvent {
  id             String   @id
  scope          String
  entityType     String
  entityId       String?
  action         String
  status         String
  summary        String
  details        Json
  actor          Json
  occurredAt     DateTime
  correlationId  String?
  idempotencyKey String?
  createdAt      DateTime @default(now())

  @@index([scope, occurredAt])
  @@index([entityType, entityId])
}

model FinanceIdempotencyRequest {
  id           Int      @id @default(autoincrement())
  key          String
  scope        String
  entityType   String
  entityId     String?
  action       String
  payloadHash  String
  responseCode Int
  responseBody Json
  auditEventId String?
  createdAt    DateTime @default(now())

  @@unique([scope, key], name: "finance_scope_key")
}

model BillingInvoice {
  id                Int      @id @default(autoincrement())
  companyId         Int
  company           Company  @relation(fields: [companyId], references: [id])
  planCode          String
  billingCycle      String
  status            String   @default("open")
  amountCents       Int
  currency          String   @default("BRL")
  dueDate           DateTime
  paidAt            DateTime?
  externalRef       String?
  metadataJson      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  attempts          PaymentAttempt[]
  billingEvents     BillingEvent[]

  @@index([companyId, status, dueDate])
}

model PaymentAttempt {
  id                Int            @id @default(autoincrement())
  invoiceId         Int
  invoice           BillingInvoice @relation(fields: [invoiceId], references: [id])
  companyId         Int
  company           Company        @relation(fields: [companyId], references: [id])
  attemptNumber     Int
  provider          String
  providerInvoiceId String
  providerEventId   String?
  status            String         @default("pending")
  errorCode         String?
  errorMessage      String?
  checkoutUrl       String?
  pixCode           String?
  boletoUrl         String?
  paidAt            DateTime?
  providerPayload   Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  billingEvents     BillingEvent[]

  @@unique([invoiceId, attemptNumber], name: "billing_invoice_attempt_unique")
  @@index([provider, providerInvoiceId])
}

model BillingEvent {
  id               Int             @id @default(autoincrement())
  companyId        Int
  company          Company         @relation(fields: [companyId], references: [id])
  invoiceId        Int?
  invoice          BillingInvoice? @relation(fields: [invoiceId], references: [id])
  paymentAttemptId Int?
  paymentAttempt   PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id])
  eventType        String
  eventStatus      String
  summary          String
  metadataJson     Json?
  occurredAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())

  @@index([companyId, occurredAt])
  @@index([invoiceId, occurredAt])
  @@index([paymentAttemptId, occurredAt])
}

model Notification {
  id              Int      @id @default(autoincrement())
  recipientUserId Int
  type            String
  title           String
  body            String
  href            String   @default("/")
  read            Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [recipientUserId], references: [id])
}
