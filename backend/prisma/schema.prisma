generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String
  role      String
  processes Process[]
}

model Client {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  type       String    @default("PF")
  cpfCnpj    String?
  phone      String?
  email      String?
  address    String?
  status     String    @default("ativo")
  legalArea  String?
  responsible String?
  notes      String?
  createdAt  DateTime  @default(now())
  processes  Process[]
  atendimentos Atendimento[]
  tasks      Task[]
  agendaEvents AgendaEvent[]
  publications Publication[]
}

model Process {
  id           Int           @id @default(autoincrement())
  title        String
  processNumber String?      @unique
  client       String
  clientId     Int?
  clientRecord Client?       @relation(fields: [clientId], references: [id])
  phase        String
  status       String
  ownerId      Int
  owner        User          @relation(fields: [ownerId], references: [id])
  andamentos   Andamento[]
  prazos       Prazo[]
  documentos   Documento[]
  atendimentos Atendimento[]
  tasks        Task[]
  agendaEvents AgendaEvent[]
  publications Publication[]
}

model Publication {
  id                Int      @id @default(autoincrement())
  processId         Int
  process           Process  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?  @relation(fields: [clientId], references: [id])
  publicationType   String
  status            String   @default("nova")
  impact            String   @default("medio")
  tribunal          String
  origin            String
  publishedAt       DateTime
  summary           String
  relevantText      String
  requiresAction    Boolean  @default(false)
  convertedToDeadline Boolean @default(false)
  derivedDeadlineLabel String?
  notes             String?
  read              Boolean  @default(false)
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Andamento {
  id          Int      @id @default(autoincrement())
  processId   Int
  process     Process  @relation(fields: [processId], references: [id])
  title       String
  description String
  date        DateTime @default(now())
  actorEmail  String
}

model Prazo {
  id          Int      @id @default(autoincrement())
  processId   Int
  process     Process  @relation(fields: [processId], references: [id])
  title       String
  dueDate     DateTime
  status      String   @default("aberto")
  priority    String   @default("media")
  origin      String   @default("interno")
  responsible String?
  legalArea   String?
  notes       String?
  completedAt DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Documento {
  id                Int      @id @default(autoincrement())
  processId         Int
  process           Process  @relation(fields: [processId], references: [id])
  title             String
  description       String
  status            String   @default("pendente")
  category          String   @default("Checklist")
  version           Int      @default(1)
  isLatestVersion   Boolean  @default(true)
  origin            String   @default("interno")
  uploadedAt        DateTime @default(now())
  responsible       String?
  requiredChecklist Boolean  @default(false)
  pendingForAdvance Boolean  @default(false)
  mimeType          String   @default("application/octet-stream")
  previewUrl        String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Atendimento {
  id                Int       @id @default(autoincrement())
  processId         Int?
  process           Process?  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?   @relation(fields: [clientId], references: [id])
  subject           String    @map("title")
  summary           String    @map("description")
  notes             String?
  occurredAt        DateTime  @default(now()) @map("date")
  channel           String    @default("interno")
  type              String    @default("rotina")
  status            String    @default("aberto")
  priority          String    @default("media")
  responsible       String?
  nextStep          String?
  scheduledReturnAt DateTime?
  critical          Boolean   @default(false)
  actorEmail        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  agendaEvents      AgendaEvent[]
}

model Task {
  id                Int       @id @default(autoincrement())
  title             String
  description       String
  processId         Int?
  process           Process?  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?   @relation(fields: [clientId], references: [id])
  clientName        String?
  origin            String    @default("interno")
  dueDate           DateTime
  status            String    @default("pendente")
  priority          String    @default("media")
  owner             String
  createdBy         String
  notes             String?
  linkedToDeadline  Boolean   @default(false)
  linkedToPublication Boolean @default(false)
  linkedToDocument  Boolean   @default(false)
  immediateAction   Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  agendaEvents      AgendaEvent[]
}

model AgendaEvent {
  id                Int          @id @default(autoincrement())
  title             String
  eventType         String
  status            String       @default("agendado")
  priority          String       @default("media")
  startAt           DateTime
  endAt             DateTime
  processId         Int?
  process           Process?     @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?      @relation(fields: [clientId], references: [id])
  attendanceId      Int?
  attendance        Atendimento? @relation(fields: [attendanceId], references: [id])
  taskId            Int?
  task              Task?        @relation(fields: [taskId], references: [id])
  responsible       String?
  locationOrChannel String?
  notes             String?
  origin            String       @default("manual")
  createdBy         String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Template {
  id               Int      @id @default(autoincrement())
  name             String
  legalArea        String
  pieceType        String
  status           String   @default("ativo")
  official         Boolean  @default(false)
  favorite         Boolean  @default(false)
  autoFill         Boolean  @default(false)
  phase            String
  author           String
  version          String   @default("v1.0")
  updatedOn        DateTime @default(now())
  lastUsedAt       DateTime?
  needsReview      Boolean  @default(false)
  description      String
  tags             Json
  placeholders     Json
  preview          String
  versionsJson     Json
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
