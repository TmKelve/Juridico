generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String
  role      String
  processes Process[]
}

model Client {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  type       String    @default("PF")
  cpfCnpj    String?
  phone      String?
  email      String?
  address    String?
  status     String    @default("ativo")
  legalArea  String?
  responsible String?
  notes      String?
  createdAt  DateTime  @default(now())
  processes  Process[]
  atendimentos Atendimento[]
  tasks      Task[]
  agendaEvents AgendaEvent[]
  publications Publication[]
  publicationEvents PublicationEvent[]
  triageItems TriageItem[]
  crmLeads CrmLead[]
  crmOpportunities CrmOpportunity[]
  financeEntries FinanceEntry[]
  financeInstallmentPlans FinanceInstallmentPlan[]
}

model Process {
  id           Int           @id @default(autoincrement())
  title        String
  processNumber String?      @unique
  client       String
  clientId     Int?
  clientRecord Client?       @relation(fields: [clientId], references: [id])
  phase        String
  status       String
  ownerId      Int
  owner        User          @relation(fields: [ownerId], references: [id])
  andamentos   Andamento[]
  prazos       Prazo[]
  documentos   Documento[]
  atendimentos Atendimento[]
  tasks        Task[]
  agendaEvents AgendaEvent[]
  publications Publication[]
  publicationEvents PublicationEvent[]
  triageItems TriageItem[]
  financeEntries FinanceEntry[]
  financeInstallmentPlans FinanceInstallmentPlan[]
}

model Publication {
  id                Int      @id @default(autoincrement())
  processId         Int
  process           Process  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?  @relation(fields: [clientId], references: [id])
  publicationType   String
  status            String   @default("nova")
  impact            String   @default("medio")
  tribunal          String
  origin            String
  publishedAt       DateTime
  summary           String
  relevantText      String
  requiresAction    Boolean  @default(false)
  convertedToDeadline Boolean @default(false)
  derivedDeadlineLabel String?
  derivedDeadlineId Int?
  notes             String?
  read              Boolean  @default(false)
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  publicationEvents PublicationEvent[]
}

model PublicationCapture {
  id                Int      @id @default(autoincrement())
  sourceType        String
  sourceReference   String
  capturedAt        DateTime @default(now())
  occurredAt        DateTime
  rawText           String
  normalizedText    String
  tribunal          String?
  processNumber     String?
  oabNumber         String?
  lawyerName        String?
  cpf               String?
  personName        String?
  metadataJson      Json
  fingerprint       String   @unique
  status            String   @default("novo")
  sourceJobId       Int?
  sourceJob         PublicationSourceJob? @relation(fields: [sourceJobId], references: [id])
  publicationEvents PublicationEvent[]
  triageItems       TriageItem[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PublicationEvent {
  id               Int      @id @default(autoincrement())
  captureId        Int
  capture          PublicationCapture @relation(fields: [captureId], references: [id])
  processId        Int?
  process          Process? @relation(fields: [processId], references: [id])
  clientId         Int?
  clientRecord     Client?  @relation(fields: [clientId], references: [id])
  publicationId    Int?
  publication      Publication? @relation(fields: [publicationId], references: [id])
  eventType        String
  eventAt          DateTime
  title            String
  summary          String
  fullText         String
  riskLevel        String   @default("normal")
  requiresAction   Boolean  @default(false)
  timelinePosition Int      @default(0)
  triageItems      TriageItem[]
  createdAt        DateTime @default(now())
}

model PublicationSourceJob {
  id                Int      @id @default(autoincrement())
  sourceType        String
  scheduledFor      DateTime
  startedAt         DateTime?
  finishedAt        DateTime?
  status            String   @default("pending")
  itemsCaptured     Int      @default(0)
  itemsCreated      Int      @default(0)
  itemsUpdated      Int      @default(0)
  itemsFlaggedCritical Int   @default(0)
  itemsSentToCrm    Int      @default(0)
  errorLog          String?
  captures          PublicationCapture[]
  createdAt         DateTime @default(now())
}

model CrmLead {
  id             Int      @id @default(autoincrement())
  clientId       Int?
  clientRecord   Client?  @relation(fields: [clientId], references: [id])
  cpf            String?
  personName     String
  source         String
  status         String   @default("novo")
  responsible    String?
  summary        String
  lastContactAt  DateTime?
  nextContactAt  DateTime?
  contactEvents  CrmContactEvent[]
  triageItems    TriageItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CrmOpportunity {
  id                  Int                              @id @default(autoincrement())
  clientId            Int?
  clientRecord        Client?                          @relation(fields: [clientId], references: [id])
  convertedProcessId  Int?
  cpf                 String?
  personName          String
  source              String
  status              String                           @default("acao_recomendada")
  responsible         String?
  summary             String
  lastContactAt       DateTime?
  nextContactAt       DateTime?
  contactEvents       CrmContactEvent[]
  documentAttachments CrmOpportunityDocumentAttachment[]
  triageItems         TriageItem[]
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt
}

model CrmContactEvent {
  id               Int             @id @default(autoincrement())
  crmLeadId        Int?
  crmLead          CrmLead?        @relation(fields: [crmLeadId], references: [id])
  crmOpportunityId Int?
  crmOpportunity   CrmOpportunity? @relation(fields: [crmOpportunityId], references: [id])
  kind             String          @default("contato")
  summary          String
  createdBy        String?
  createdAt        DateTime        @default(now())
}

model CrmOpportunityDocumentAttachment {
  id                Int            @id @default(autoincrement())
  crmOpportunityId  Int
  crmOpportunity    CrmOpportunity @relation(fields: [crmOpportunityId], references: [id])
  documentId        Int?
  document          Documento?     @relation(fields: [documentId], references: [id])
  titleSnapshot     String
  category          String         @default("Checklist")
  status            String         @default("ativo")
  mimeType          String         @default("application/octet-stream")
  previewUrl        String?
  requiredChecklist Boolean        @default(false)
  pendingForAdvance Boolean        @default(false)
  uploadedAt        DateTime       @default(now())
  responsible       String?
  createdBy         String?
  externalDocumentId String?
  metadata          Json
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model CrmAuditEvent {
  id             String   @id
  scope          String
  entityType     String
  entityId       Int?
  action         String
  status         String
  summary        String
  details        Json
  actor          Json
  occurredAt     DateTime
  correlationId  String?
  idempotencyKey String?
  createdAt      DateTime @default(now())
}

model CrmIdempotencyRequest {
  id           Int      @id @default(autoincrement())
  key          String
  scope        String
  entityType   String
  entityId     Int?
  action       String
  payloadHash  String
  responseCode Int
  responseBody Json
  auditEventId String?
  createdAt    DateTime @default(now())

  @@unique([scope, key], name: "scope_key")
}

model TriageItem {
  id               Int      @id @default(autoincrement())
  captureId        Int
  capture          PublicationCapture @relation(fields: [captureId], references: [id])
  eventId          Int?
  event            PublicationEvent? @relation(fields: [eventId], references: [id])
  processId        Int?
  process          Process? @relation(fields: [processId], references: [id])
  clientId         Int?
  clientRecord     Client?  @relation(fields: [clientId], references: [id])
  crmLeadId        Int?
  crmLead          CrmLead? @relation(fields: [crmLeadId], references: [id])
  crmOpportunityId Int?
  crmOpportunity   CrmOpportunity? @relation(fields: [crmOpportunityId], references: [id])
  queueType        String
  status           String   @default("pendente")
  suggestedAction  String
  suggestedReason  String
  aiConfidenceBand String?
  aiScoreRaw       Float?
  postponeUntil    DateTime?
  assignedQueue    String   @default("fila_central")
  handledBy        String?
  handledAt        DateTime?
  discardReason    String?
  discardNote      String?
  sourceLabel      String?
  decisions        TriageDecision[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TriageDecision {
  id                     Int      @id @default(autoincrement())
  triageItemId           Int
  triageItem             TriageItem @relation(fields: [triageItemId], references: [id])
  decisionType           String
  decisionReason         String?
  decisionNote           String?
  decidedBy              String
  decidedAt              DateTime @default(now())
  generatedTaskId        Int?
  generatedDeadlineId    Int?
  generatedLeadId        Int?
  generatedOpportunityId Int?
}

model Andamento {
  id          Int      @id @default(autoincrement())
  processId   Int
  process     Process  @relation(fields: [processId], references: [id])
  title       String
  description String
  date        DateTime @default(now())
  actorEmail  String
}

model Prazo {
  id                      Int         @id @default(autoincrement())
  processId               Int
  process                 Process     @relation(fields: [processId], references: [id])
  title                   String
  dueDate                 DateTime
  status                  String      @default("aberto")
  priority                String      @default("media")
  origin                  String      @default("interno")
  responsible             String?
  legalArea               String?
  notes                   String?
  publicationId           Int?
  agendaEventId           Int?        @unique
  agendaEvent             AgendaEvent? @relation(fields: [agendaEventId], references: [id])
  agendaSyncStatus        String?     @default("missing")
  completedAt             DateTime?
  completedBy             String?
  completionJustification String?
  createdBy               String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model Documento {
  id                Int      @id @default(autoincrement())
  processId         Int
  process           Process  @relation(fields: [processId], references: [id])
  title             String
  description       String
  status            String   @default("pendente")
  category          String   @default("Checklist")
  version           Int      @default(1)
  isLatestVersion   Boolean  @default(true)
  origin            String   @default("interno")
  uploadedAt        DateTime @default(now())
  responsible       String?
  requiredChecklist Boolean  @default(false)
  pendingForAdvance Boolean  @default(false)
  mimeType          String   @default("application/octet-stream")
  previewUrl        String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  crmOpportunityAttachments CrmOpportunityDocumentAttachment[]
}

model Atendimento {
  id                Int       @id @default(autoincrement())
  processId         Int?
  process           Process?  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?   @relation(fields: [clientId], references: [id])
  subject           String    @map("title")
  summary           String    @map("description")
  notes             String?
  occurredAt        DateTime  @default(now()) @map("date")
  channel           String    @default("interno")
  type              String    @default("rotina")
  status            String    @default("aberto")
  priority          String    @default("media")
  responsible       String?
  nextStep          String?
  scheduledReturnAt DateTime?
  critical          Boolean   @default(false)
  actorEmail        String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  agendaEvents      AgendaEvent[]
}

model Task {
  id                Int       @id @default(autoincrement())
  title             String
  description       String
  processId         Int?
  process           Process?  @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?   @relation(fields: [clientId], references: [id])
  clientName        String?
  origin            String    @default("interno")
  dueDate           DateTime
  status            String    @default("pendente")
  priority          String    @default("media")
  owner             String
  createdBy         String
  notes             String?
  linkedToDeadline  Boolean   @default(false)
  linkedToPublication Boolean @default(false)
  linkedToDocument  Boolean   @default(false)
  immediateAction   Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  agendaEvents      AgendaEvent[]
}

model AgendaEvent {
  id                Int          @id @default(autoincrement())
  title             String
  eventType         String
  status            String       @default("agendado")
  priority          String       @default("media")
  startAt           DateTime
  endAt             DateTime
  processId         Int?
  process           Process?     @relation(fields: [processId], references: [id])
  clientId          Int?
  clientRecord      Client?      @relation(fields: [clientId], references: [id])
  attendanceId      Int?
  attendance        Atendimento? @relation(fields: [attendanceId], references: [id])
  taskId            Int?
  task              Task?        @relation(fields: [taskId], references: [id])
  responsible       String?
  locationOrChannel String?
  notes             String?
  origin            String       @default("manual")
  createdBy         String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deadline          Prazo?
}

model Template {
  id               Int      @id @default(autoincrement())
  name             String
  legalArea        String
  pieceType        String
  status           String   @default("ativo")
  official         Boolean  @default(false)
  favorite         Boolean  @default(false)
  autoFill         Boolean  @default(false)
  phase            String
  author           String
  version          String   @default("v1.0")
  updatedOn        DateTime @default(now())
  lastUsedAt       DateTime?
  needsReview      Boolean  @default(false)
  description      String
  tags             Json
  placeholders     Json
  preview          String
  versionsJson     Json
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FinanceCategory {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  label       String
  type        String
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  entries     FinanceEntry[]
  installmentPlans FinanceInstallmentPlan[]
}

model FinanceEntry {
  id                Int             @id @default(autoincrement())
  type              String
  status            String          @default("open")
  description       String
  amountCents       Int
  settledAmountCents Int            @default(0)
  currency          String          @default("BRL")
  dueDate           DateTime
  settlementDate    DateTime?
  paymentMethod     String?
  referenceNumber   String?
  clientId          Int?
  clientRecord      Client?         @relation(fields: [clientId], references: [id])
  processId         Int?
  process           Process?        @relation(fields: [processId], references: [id])
  installmentPlanId Int?
  installmentPlan   FinanceInstallmentPlan? @relation(fields: [installmentPlanId], references: [id])
  installmentNumber Int?
  categoryCode      String
  category          FinanceCategory @relation(fields: [categoryCode], references: [code])
  responsibleUserId Int?
  notes             String?
  externalRef       String?
  createdBy         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  charges           FinanceCharge[]
  reconciliationMatches FinanceReconciliationMatch[]
  collectionSchedules FinanceCollectionSchedule[]

  @@index([type, status, dueDate])
  @@index([clientId, status])
  @@index([processId, status])
  @@index([installmentPlanId, installmentNumber])
}

model FinanceInstallmentPlan {
  id                    Int            @id @default(autoincrement())
  description           String
  clientId              Int?
  clientRecord          Client?        @relation(fields: [clientId], references: [id])
  processId             Int?
  process               Process?       @relation(fields: [processId], references: [id])
  categoryCode          String
  category              FinanceCategory @relation(fields: [categoryCode], references: [code])
  installmentCount      Int
  installmentAmountCents Int
  totalAmountCents      Int
  dueDay                Int
  firstDueDate          DateTime
  active                Boolean        @default(true)
  notes                 String?
  createdBy             String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  entries               FinanceEntry[]

  @@index([clientId, active])
  @@index([processId, active])
}

model FinanceCharge {
  id              Int      @id @default(autoincrement())
  entryId         Int
  entry           FinanceEntry @relation(fields: [entryId], references: [id])
  method          String
  status          String   @default("draft")
  provider        String   @default("mock")
  externalId      String   @unique
  paymentUrl      String?
  pixCode         String?
  boletoBarcode   String?
  expiresAt       DateTime?
  paidAt          DateTime?
  amountCents     Int
  recipientEmail  String?
  recipientPhone  String?
  providerPayload Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  events          FinanceChargeEvent[]

  @@index([entryId, status])
}

model FinanceChargeEvent {
  id            Int      @id @default(autoincrement())
  chargeId      Int
  charge        FinanceCharge @relation(fields: [chargeId], references: [id])
  providerEventId String?
  eventType     String
  status        String
  payload       Json
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  @@unique([chargeId, providerEventId], name: "charge_provider_event_unique")
}

model FinanceReconciliationRun {
  id            Int      @id @default(autoincrement())
  referenceDate DateTime
  status        String   @default("pending")
  source        String   @default("manual")
  importedLines Int      @default(0)
  matchedLines  Int      @default(0)
  unmatchedLines Int     @default(0)
  summaryJson   Json
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  matches       FinanceReconciliationMatch[]
}

model FinanceReconciliationMatch {
  id            Int      @id @default(autoincrement())
  runId         Int
  run           FinanceReconciliationRun @relation(fields: [runId], references: [id])
  entryId       Int?
  entry         FinanceEntry? @relation(fields: [entryId], references: [id])
  externalId    String
  status        String   @default("pending")
  occurredAt    DateTime
  amountCents   Int
  description   String
  matchedAt     DateTime?
  metadata      Json
  createdAt     DateTime @default(now())

  @@index([runId, status])
  @@index([entryId, status])
}

model FinanceCollectionSchedule {
  id              Int      @id @default(autoincrement())
  entryId         Int
  entry           FinanceEntry @relation(fields: [entryId], references: [id])
  channel         String
  cadenceDays     Int
  maxAttempts     Int
  startsAt        DateTime
  nextRunAt       DateTime
  active          Boolean  @default(true)
  lastAttemptAt   DateTime?
  status          String   @default("scheduled")
  templateCode    String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  attempts        FinanceCollectionAttempt[]
}

model FinanceCollectionAttempt {
  id            Int      @id @default(autoincrement())
  scheduleId    Int
  schedule      FinanceCollectionSchedule @relation(fields: [scheduleId], references: [id])
  attemptNumber Int
  status        String   @default("scheduled")
  channel       String
  destination   String?
  message       String
  providerPayload Json
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@unique([scheduleId, attemptNumber], name: "collection_schedule_attempt_unique")
}

model FinanceAuditEvent {
  id             String   @id
  scope          String
  entityType     String
  entityId       String?
  action         String
  status         String
  summary        String
  details        Json
  actor          Json
  occurredAt     DateTime
  correlationId  String?
  idempotencyKey String?
  createdAt      DateTime @default(now())

  @@index([scope, occurredAt])
  @@index([entityType, entityId])
}

model FinanceIdempotencyRequest {
  id           Int      @id @default(autoincrement())
  key          String
  scope        String
  entityType   String
  entityId     String?
  action       String
  payloadHash  String
  responseCode Int
  responseBody Json
  auditEventId String?
  createdAt    DateTime @default(now())

  @@unique([scope, key], name: "finance_scope_key")
}
