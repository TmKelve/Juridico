PORT=3000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-me-in-production

# Runtime soberano atual
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/juridico_dev?schema=public

# Opcional durante transicao local
POSTGRES_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/juridico_dev?schema=public

# ── DataJud CNJ (integração gratuita de lookup de processos) ────────────────────
# Obtenha sua chave em: https://www.cnj.jus.br/sistemas/datajud/
# A chave abaixo é pública/demo (limite de requisições — use a sua em produção):
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZFRlUQ==

# Epic B - provider de cobranca
FINANCE_PAYMENT_PROVIDER=mock
FINANCE_PROVIDER_BASE_URL=https://sandbox.provider.local
FINANCE_PROVIDER_API_KEY=change-me
FINANCE_PROVIDER_CHARGE_PATH=/payments
FINANCE_PROVIDER_WEBHOOK_SECRET=change-me
FINANCE_SCHEDULER_ENABLED=0

# ── Desenvolvimento local (mock offline e seed) ─────────────────────────────
# Senha dos usuários de mock offline e do seed inicial. Nunca definir em produção
# (devMock é desativado automaticamente quando NODE_ENV=production).
# Sobrescreva em .env.local para evitar commitar senha real de dev.
LEXORA_DEV_PASSWORD=123456
LEXORA_SEED_PASSWORD=123456

# ── Vercel Blob (storage de documentos) ─────────────────────────────────────
# Obtenha em: Vercel Dashboard → Storage → Create Store → Blob → Connect ao projeto juridico
# Copie BLOB_READ_WRITE_TOKEN e adicione aqui e no painel Render.
# Sem este token, uploads usam disco local (ephemeral no Render — perda de dados).
BLOB_READ_WRITE_TOKEN=

# ── IA — Provider LLM externo ────────────────────────────────────────────────
# Ativa o RemoteAiProvider em substituição ao DeterministicAiProvider padrão.
# Sem estas vars, a IA opera em modo determinístico (sem LLM real).
# Antes de ativar: definir política de mascaramento de dados sensíveis (BL-075).
# Requer decisão formal (ADR-004).
AI_PROVIDER_URL=https://seu-provider-llm.example.com/v1
AI_PROVIDER_TOKEN=change-me
AI_PROVIDER_AUTH_HEADER=Authorization

# ── IA — Triagem automática ──────────────────────────────────────────────────
# Provider específico para o serviço de triagem de publicações.
# Pode ser o mesmo LLM ou um endpoint dedicado.
# TRIAGE_SCHEDULER_DISABLED=1 desabilita o scheduler de triagem completamente.
TRIAGE_AI_URL=https://seu-provider-triage.example.com/v1
TRIAGE_AI_TOKEN=change-me
TRIAGE_AI_AUTH_HEADER=Authorization
TRIAGE_SCHEDULER_DISABLED=0

# ── Integrações de publicações ───────────────────────────────────────────────
# Endpoints para coleta de publicações jurídicas por fonte.
# Cada fonte tem URL, token de autenticação e header configuráveis.
# Deixe em branco para desativar a fonte; o coletor ignora fontes sem URL.

# CNJ (Conselho Nacional de Justiça)
CNJ_PUBLICATIONS_URL=
CNJ_PUBLICATIONS_TOKEN=
CNJ_PUBLICATIONS_AUTH_HEADER=Authorization

# CPF / publicações por CPF
CPF_PUBLICATIONS_URL=
CPF_PUBLICATIONS_TOKEN=
CPF_PUBLICATIONS_AUTH_HEADER=Authorization

# Diário Oficial
DIARIO_PUBLICATIONS_URL=
DIARIO_PUBLICATIONS_TOKEN=
DIARIO_PUBLICATIONS_AUTH_HEADER=Authorization

# OAB (Ordem dos Advogados do Brasil)
OAB_PUBLICATIONS_URL=
OAB_PUBLICATIONS_TOKEN=
OAB_PUBLICATIONS_AUTH_HEADER=Authorization

# Lookup de processos por número
PROCESS_LOOKUP_URL=
PROCESS_LOOKUP_TOKEN=
PROCESS_LOOKUP_AUTH_HEADER=Authorization
