{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "prisma migrate deploy --schema=prisma/schema.prisma && node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "prisma:postgres:validate": "prisma validate --schema=prisma/schema.postgres.prisma",
    "prisma:postgres:generate": "prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:postgres:pull": "prisma db pull --schema=prisma/schema.postgres.prisma --print",
    "prisma:postgres:status": "prisma migrate status --schema=prisma/schema.postgres.prisma",
    "prisma:postgres:migrate:dev": "prisma migrate dev --schema=prisma/schema.postgres.prisma",
    "prisma:cutover:validate": "prisma validate --schema=prisma-postgres/schema.prisma",
    "prisma:cutover:generate": "prisma generate --schema=prisma-postgres/schema.prisma",
    "prisma:cutover:status": "prisma migrate status --schema=prisma-postgres/schema.prisma",
    "prisma:cutover:migrate:create": "prisma migrate dev --schema=prisma-postgres/schema.prisma --create-only",
    "prisma:cutover:migrate:dev": "prisma migrate dev --schema=prisma-postgres/schema.prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/client": "^4.16.2",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^4.16.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "pg": "^8.21.0"
  }
}
