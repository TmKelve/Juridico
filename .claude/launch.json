{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "lexora-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "lexora-backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "backend"
    },
    {
      "name": "lexora-prisma-studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "prisma:studio"],
      "port": 5555,
      "cwd": "backend"
    }
  ]
}
